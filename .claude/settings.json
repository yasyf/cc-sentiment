{
  "effortLevel": "max",
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max"
  },
  "permissions": {
    "allow": [
      "Bash(.claude/skills/**/*.sh)",
      "Bash(.venv/bin/python:*)",
      "Bash(~/.bun/bin/codex:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PermissionRequest"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PostToolUse"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PostToolUseFailure"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run PreToolUse"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook review run",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run SessionStart --async",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run Stop"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uvx capt-hook run UserPromptSubmit"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "cc-notes": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-notes"
      }
    },
    "skills": {
      "source": {
        "source": "github",
        "repo": "yasyf/cc-skills"
      },
      "autoUpdate": true
    }
  },
  "enabledPlugins": {
    "cc-notes@cc-notes": true,
    "cc-context@skills": true
  }
}
